# ============================================================
# Coupang 选品系统 - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- 数据库配置 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=coupang_selection

# ---- OpenAI API (用于AI分析) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4

# ---- Coupang 卖家后台账号 ----
COUPANG_SELLER_EMAIL=your_email@example.com
COUPANG_SELLER_PASSWORD=your_password_here

# ---- 代理IP配置 (可选) ----
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASSWORD=
