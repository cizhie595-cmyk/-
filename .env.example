# ============================================================
# Coupang 选品系统 - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- 数据库配置 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=coupang_selection

# ---- OpenAI API (用于AI分析) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4

# ---- Coupang 卖家后台账号 ----
COUPANG_SELLER_EMAIL=your_email@example.com
COUPANG_SELLER_PASSWORD=your_password_here

# ---- 代理IP配置 (可选) ----
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASSWORD=

# ---- JWT 认证配置 (用户登录模块) ----
JWT_SECRET_KEY=your-random-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Flask 配置 ----
FLASK_SECRET_KEY=your-flask-secret-key
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
