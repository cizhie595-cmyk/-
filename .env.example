# ============================================================
# Coupang 跨境电商智能选品系统 - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- 数据库配置 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=coupang_selection
# 连接池配置
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# ---- Redis 配置 (Celery 异步任务) ----
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_URL=redis://localhost:6379/1

# ---- OpenAI API (用于 AI 分析) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4

# ---- Coupang 卖家后台账号 ----
COUPANG_SELLER_EMAIL=your_email@example.com
COUPANG_SELLER_PASSWORD=your_password_here

# ---- 第三方 API 密钥 ----
# Keepa API (Amazon 历史数据)
# KEEPA_API_KEY=your-keepa-api-key

# Naver API (韩国搜索趋势)
# NAVER_CLIENT_ID=your-naver-client-id
# NAVER_CLIENT_SECRET=your-naver-client-secret

# ---- 代理 IP 配置 (可选) ----
PROXY_URL=
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USER=
# PROXY_PASSWORD=

# ---- 安全配置 (生产环境必须修改!) ----
# JWT 签名密钥 - 建议使用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成
JWT_SECRET_KEY=your-random-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Flask Session 密钥 - 建议使用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成
FLASK_SECRET_KEY=your-flask-secret-key-change-this-in-production

# API 密钥加密密钥 (AES-256-GCM) - 建议使用 `python -c "import secrets; print(secrets.token_hex(32))"` 生成
# 64 位十六进制字符串 (32 字节)
API_KEYS_ENCRYPTION_KEY=your-64-char-hex-encryption-key-change-this

# ---- Flask 运行配置 ----
FLASK_ENV=production
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ---- 爬虫配置 ----
# 最小请求间隔(秒)
SCRAPER_MIN_DELAY=1.0
# 最大请求间隔(秒)
SCRAPER_MAX_DELAY=3.0

# ---- 数据存储 ----
DATA_DIR=data

# ---- Amazon Affiliate Tags (返佣链接) ----
AFFILIATE_TAG_AMAZON_US=
AFFILIATE_TAG_AMAZON_UK=
AFFILIATE_TAG_AMAZON_DE=
AFFILIATE_TAG_AMAZON_JP=
AFFILIATE_TAG_AMAZON_CA=

# ---- Coupang Partners Tag (返佣链接) ----
AFFILIATE_TAG_COUPANG=

# ---- SMTP 邮件配置 (邮箱验证/密码重置) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true

# ---- Stripe 支付 (订阅付费) ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- OAuth 第三方登录 (可选) ----
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
